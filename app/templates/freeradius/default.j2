#
# This file is generated by Radiusaurus.
# Handles outer authentication and MAC authentication.
#

server default {
    listen {
        type = auth
        ipaddr = *
        port = {{ auth_port }}
    }

    listen {
        type = acct
        ipaddr = *
        port = {{ accounting_port }}
    }

    authorize {
        preprocess

        # MAC authentication path.
        if (&User-Name =~ /^[0-9a-fA-F]{12}$/) {
            update control {
                Auth-Type := Accept
            }
            sql
            expiration
            logintime
            return
        }

        eap {
            ok = return
        }

        sql
        expiration
        logintime
    }

    authenticate {
        Auth-Type Accept {
            accept
        }

        eap
    }

    preacct {
        preprocess
        acct_unique
        suffix
        files
    }

    accounting {
        detail
        sql
        exec
        attr_filter.accounting_response
    }

    session {
        sql
    }

    post-auth {
        update {
            &reply: += &session-state:
        }

        sql
        radius_request_log

        Post-Auth-Type REJECT {
            sql
            radius_request_log
            attr_filter.access_reject
        }
    }
}

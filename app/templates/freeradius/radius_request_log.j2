#
# This file is generated by Radiusaurus.
# Logs RADIUS request details to a readable FreeRADIUS log file.
#

linelog radius_request_log {
    filename = "{{ radius_request_log_file }}"
    escape_filenames = no
    syslog_severity = "info"
    permissions = 0600

    {% raw %}
    format = "type=%{%{Packet-Type}:-unknown} user=%{%{User-Name}:-unknown} nas_ip=%{%{NAS-IP-Address}:-unknown} client_ip=%{Packet-Src-IP-Address} calling_station=%{%{Calling-Station-Id}:-unknown} called_station=%{%{Called-Station-Id}:-unknown} result=%{%{reply:Packet-Type}:-none} failure=%{%{Module-Failure-Message}:-none}"
    {% endraw %}
}
